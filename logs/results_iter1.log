engineer (to main_cmbagent_chat):

**Code Explanation:**

The code performs the boundary delineation in Fourier space by computing the empirical characteristic function $\phi(k, t)$ for each mechanism at four selected time points. It first uses a broad logarithmic grid of wavenumbers $k$ to identify the low-$k$ regime where $|\phi(k, t)| > 0.1$. In this regime, it estimates the generalized diffusion coefficient $D_\alpha$ by performing a least-squares linear regression of $-\log|\phi(k, t)|$ against $k^\alpha t$, forcing the fit through the origin. 

Using the estimated $D_\alpha$, the code determines a maximum wavenumber $k_{max}$ such that the theoretical Fractional Fokker-Planck (FFP) characteristic function $\exp(-D_\alpha k^\alpha t)$ drops to $0.05$. It then computes the empirical characteristic function on a linear grid up to $1.5 \times k_{max}$ to focus on the high-frequency regime. The ratio of the empirical to the theoretical FFP characteristic function is plotted, with a shaded band indicating a $\pm 10\%$ tolerance. This visualization highlights the specific scales (high $k$) where the FFP approximation fails due to microscopic details, finite velocity, or finite sample size. The estimated $D_\alpha$ and $k_{max}$ values are printed to the console and saved to a JSON file.

**Python Code:**

```python
import sys
import os
import numpy as np
import matplotlib.pyplot as plt
import json
from datetime import datetime

def get_time(filename, index, data_dir):
    """
    Retrieves the physical time corresponding to a given index for a specific dataset.
    """
    if 'ctrw' in filename:
        tgrid = np.load(os.path.join(data_dir, 'preprocessed_ctrw_tgrid.npy'))
        return float(tgrid[index])
    elif 'levy_lorentz' in filename:
        tgrid = np.load(os.path.join(data_dir, 'preprocessed_levy_lorentz_tgrid.npy'))
        return float(tgrid[index])
    elif 'sisyphus' in filename:
        return float(index * 0.1)
    else:
        return float(index)

def main():
    plt.rcParams['text.usetex'] = False
    data_dir = 'data/'
    
    # Mapping of filenames to their expected spatial tail index alpha
    mapping = {
        'preprocessed_pm_map_z1p5.npy': 2.0,
        'preprocessed_pm_map_z2p0.npy': 1.0,
        'preprocessed_pm_map_z2p5.npy': 0.67,
        'preprocessed_ctrw_normal_wait_gaussian_jump.npy': 2.0,
        'preprocessed_ctrw_subdiff_wait_gaussian_jump.npy': 2.0,
        'preprocessed_ctrw_normal_wait_levy_jump.npy': 1.5,
        'preprocessed_ctrw_subdiff_wait_levy_jump.npy': 1.5,
        'preprocessed_levy_lorentz_alpha0p5.npy': 0.5,
        'preprocessed_levy_lorentz_alpha1p0.npy': 1.0,
        'preprocessed_levy_lorentz_alpha1p5.npy': 1.5,
        'preprocessed_levy_lorentz_alpha2p0.npy': 2.0,
        'preprocessed_sisyphus_strong_cooling.npy': 2.0,
        'preprocessed_sisyphus_moderate_cooling.npy': 1.5,
        'preprocessed_sisyphus_weak_cooling.npy': 1.0,
        'preprocessed_levy_stable_alpha0p5.npy': 0.5,
        'preprocessed_levy_stable_alpha1p0.npy': 1.0,
        'preprocessed_levy_stable_alpha1p5.npy': 1.5,
        'preprocessed_levy_stable_alpha2p0.npy': 2.0
    }
    
    timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')
    plot_number = 1
    
    results = {}
    
    print("Starting Fourier Space Boundary Delineation...")
    print("-" * 85)
    header = f"{'Mechanism':<45} | {'Time':<8} | {'D_alpha':<10} | {'k_max':<10}"
    print(header)
    print("-" * 85)
    
    for filename, alpha in mapping.items():
        filepath = os.path.join(data_dir, filename)
        if not os.path.exists(filepath):
            continue
            
        data = np.load(filepath)
        N = data.shape[1]
        indices = [N//10, N//4, N//2, N-1]
        
        fig, axs = plt.subplots(2, 2, figsize=(12, 8))
        axs = axs.flatten()
        
        file_results = []
        
        for i, idx in enumerate(indices):
            t = get_time(filename, idx, data_dir)
            if t <= 0:
                continue
                
            X = data[:, idx]
            
            # Use the 90th percentile as a robust scale measure for heavy-tailed distributions
            scale_X = np.percentile(np.abs(X), 90)
            if scale_X == 0 or np.isnan(scale_X):
                scale_X = 1.0
            
            # Broad log grid to find D_alpha
            k_min_log = 1e-4 / scale_X
            k_max_log = 1e2 / scale_X
            k_log = np.logspace(np.log10(k_min_log), np.log10(k_max_log), 500)
            
            # Compute empirical characteristic function
            phi_complex_log = np.mean(np.exp(1j * np.outer(k_log, X)), axis=1)
            phi_log = np.abs(phi_complex_log)
            
            # Fit D_alpha in the low-k regime where phi > 0.1
            valid = phi_log > 0.1
            if np.sum(valid) > 5:
                k_valid = k_log[valid]
                phi_valid = phi_log[valid]
                
                y = -np.log(phi_valid)
                x = (k_valid ** alpha) * t
                
                # Least squares fit: y = D_alpha * x
                D_alpha = np.sum(x * y) / np.sum(x ** 2)
            else:
                D_alpha = np.nan
                
            if np.isnan(D_alpha) or D_alpha <= 1e-15:
                D_alpha = 1.0
                k_max_lin = 10.0 / scale_X
            else:
                # Define k_max such that exp(-D_alpha * k^alpha * t) = 0.05
                val = 2.995 / (D_alpha * t)
                if val > 0:
                    k_max_lin = val ** (1.0 / alpha)
                else:
                    k_max_lin = 10.0 / scale_X
                    
            # Linear grid for plotting, focusing on the high-frequency regime
            k_lin = np.linspace(0.0001, 1.5 * k_max_lin, 500)
            phi_complex_lin = np.mean(np.exp(1j * np.outer(k_lin, X)), axis=1)
            phi_lin = np.abs(phi_complex_lin)
            
            phi_th = np.exp(-D_alpha * (k_lin ** alpha) * t)
            
            safe_mask = phi_th > 1e-5
            ratio = np.full_like(phi_lin, np.nan)
            ratio[safe_mask] = phi_lin[safe_mask] / phi_th[safe_mask]
            
            ax = axs[i]
            ax.plot(k_lin[safe_mask], ratio[safe_mask], 'b-', linewidth=2, label='Empirical / FFP')
            ax.axhline(1.0, color='k', linestyle='--')
            ax.fill_between(k_lin[safe_mask], 0.9, 1.1, color='gray', alpha=0.3, label='+/- 10% tolerance')
            
            ax.set_ylim(0.0, 2.5)
            ax.set_xlabel('Wavenumber k')
            ax.set_ylabel('Ratio $\phi(k,t) / \phi_{FFP}(k,t)$')
            ax.set_title(f't = {t:.1f} | $D_{{\\alpha}}$ = {D_alpha:.2e}')
            if i == 0:
                ax.legend(loc='upper right', fontsize='small')
            ax.grid(True, linestyle='--', alpha=0.7)
            
            file_results.append({
                'time': t,
                'D_alpha': float(D_alpha),
                'k_max_lin': float(k_max_lin)
            })
            
            row = f"{filename.replace('preprocessed_', '').replace('.npy', ''):<45} | {t:<8.1f} | {D_alpha:<10.2e} | {k_max_lin:<10.2e}"
            print(row)
            
        plt.tight_layout()
        plt.suptitle(f'Fourier Space Ratio: {filename.replace("preprocessed_", "").replace(".npy", "")}', y=1.02)
        plot_filename = f'fourier_ratio_{filename.replace("preprocessed_", "").replace(".npy", "")}_{plot_number}_{timestamp}.png'
        plt.savefig(os.path.join(data_dir, plot_filename), dpi=300, bbox_inches='tight')
        print(f"Plot saved to data/{plot_filename}")
        plt.close()
        plot_number += 1
        
        results[filename] = {
            'alpha': alpha,
            'time_points': file_results
        }
        
    with open(os.path.join(data_dir, 'fourier_space_metrics.json'), 'w') as f:
        json.dump(results, f, indent=4)
    print(f"Metrics saved to data/fourier_space_metrics.json")

if __name__ == '__main__':
    main()
```

