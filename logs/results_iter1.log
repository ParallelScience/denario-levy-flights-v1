                title_str = name + '\nPeak/Core Ratio: ' + str(round(ratio_peak_to_core, 3)) if ratio_peak_to_core != float('inf') else name + '\nPeak/Core Ratio: INF'
                ax.set_title(title_str, fontsize=10)
